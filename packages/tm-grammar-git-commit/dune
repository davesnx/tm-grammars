(library
 (name tm_grammar_git_commit)
 (public_name tm-grammars.git-commit))

(rule
 (alias gen)
 (deps ../../vendor/git-commit.json ../../scripts/gen_pkg_module.sh)
 (targets tm_grammar_git_commit.ml tm_grammar_git_commit.mli)
 (mode
  (promote (until-clean)))
 (action
  (run bash ../../scripts/gen_pkg_module.sh git-commit ../../vendor/git-commit.json)))
