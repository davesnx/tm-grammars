(library
 (name tm_grammar_rst)
 (public_name tm-grammars.rst))

(rule
 (alias gen)
 (deps ../../vendor/rst.json ../../scripts/gen_pkg_module.sh)
 (targets tm_grammar_rst.ml tm_grammar_rst.mli)
 (mode
  (promote (until-clean)))
 (action
  (run bash ../../scripts/gen_pkg_module.sh rst ../../vendor/rst.json)))
