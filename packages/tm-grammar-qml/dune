(library
 (name tm_grammar_qml)
 (public_name tm-grammars.qml))

(rule
 (alias gen)
 (deps ../../vendor/qml.json ../../scripts/gen_pkg_module.sh)
 (targets tm_grammar_qml.ml tm_grammar_qml.mli)
