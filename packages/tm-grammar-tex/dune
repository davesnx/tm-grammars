(library
 (name tm_grammar_tex)
 (public_name tm-grammars.tex))

(rule
 (alias gen)
 (deps ../../vendor/tex.json ../../scripts/gen_pkg_module.sh)
 (targets tm_grammar_tex.ml tm_grammar_tex.mli)
 (mode
  (promote (until-clean)))
 (action
  (run bash ../../scripts/gen_pkg_module.sh tex ../../vendor/tex.json)))
