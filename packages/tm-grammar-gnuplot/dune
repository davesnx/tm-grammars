(library
 (name tm_grammar_gnuplot)
 (public_name tm-grammars.gnuplot))

(rule
 (alias gen)
 (deps ../../vendor/gnuplot.json ../../scripts/gen_pkg_module.sh)
 (targets tm_grammar_gnuplot.ml tm_grammar_gnuplot.mli)
 (mode
  (promote (until-clean)))
 (action
  (run bash ../../scripts/gen_pkg_module.sh gnuplot ../../vendor/gnuplot.json)))
