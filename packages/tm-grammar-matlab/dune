(library
 (name tm_grammar_matlab)
 (public_name tm-grammars.matlab))

(rule
 (alias gen)
 (deps ../../vendor/matlab.json ../../scripts/gen_pkg_module.sh)
 (targets tm_grammar_matlab.ml tm_grammar_matlab.mli)
 (mode
  (promote (until-clean)))
 (action
  (run bash ../../scripts/gen_pkg_module.sh matlab ../../vendor/matlab.json)))
